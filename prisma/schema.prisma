generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN        // Kept for internal/platform admin use
  EMPLOYEE     // Legacy - will migrate
  FOURNISSEUR  // Legacy - will migrate to SUPPLIER
  ACHETEUR     // Legacy - will migrate to CLIENT
  CLIENT
  SUPPLIER     // New - preferred over FOURNISSEUR
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProductType {
  BROCHURE
  DEPLIANT
  FLYER
  CARTE_DE_VISITE
}

enum PaperCategory {
  INTERIOR
  COVER
  BOTH
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
  SQUARE
}

enum InvitationType {
  SUPPLIER
  CLIENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum OnboardingStep {
  INVITED
  ACCOUNT_CREATED
  CONFIG_STARTED
  CONFIG_COMPLETED
  BRANDING_SET
  COMPLETE
}

enum SubscriptionStatus {
  PENDING
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum ActivityType {
  QUOTE_CREATED
  PDF_DOWNLOADED
  CLIENT_INVITED
  CLIENT_JOINED
  CONFIG_UPDATED
}

// ─── USER & AUTH ──────────────────────────────────────────────────────────────

model User {
  id                  String      @id @default(cuid())
  name                String
  email               String      @unique
  passwordHash        String
  role                Role        @default(CLIENT)
  emailVerified       DateTime?   // For invitation acceptance tracking
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations based on role
  quotes              Quote[]
  supplierProfile     SupplierProfile?
  clientAccess        SupplierClientAccess[] @relation("ClientAccess")
  
  // Track who invited this user (if applicable)
  invitedBy           String?
  
  @@index([email])
  @@index([role])
}

// ─── SUPPLIER PROFILE ─────────────────────────────────────────────────────────

model SupplierProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Company Info
  companyName         String
  logoUrl             String?
  
  // Branding for PDFs
  primaryColor        String             @default("#3B8BEB")
  secondaryColor      String?            // Optional accent color
  
  // Contact info for quotes
  address             String?
  phone               String?
  website             String?
  
  // Onboarding Progress
  onboardingStep      OnboardingStep     @default(INVITED)
  onboardingCompletedAt DateTime?
  
  // Status
  isActive            Boolean            @default(false)
  subscriptionStatus  SubscriptionStatus @default(PENDING)
  
  // Plan info
  planType            String             @default("trial") // trial, monthly, annual, usage
  planStartedAt       DateTime?
  planExpiresAt       DateTime?
  
  // Default config flag - if true, uses system defaults
  usesDefaultConfig   Boolean            @default(true)
  
  // Relations
  clients             SupplierClientAccess[]
  activityLogs        ActivityLog[]
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  
  @@index([userId])
  @@index([isActive])
  @@index([subscriptionStatus])
}

// ─── SUPPLIER-CLIENT RELATIONSHIP ─────────────────────────────────────────────

model SupplierClientAccess {
  id          String          @id @default(cuid())
  supplierId  String
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  clientId    String
  client      User            @relation("ClientAccess", fields: [clientId], references: [id], onDelete: Cascade)
  
  // Invitation tracking
  invitedBy   String          // User ID who sent invitation (usually supplier)
  invitedAt   DateTime        @default(now())
  
  // Client can be shared across multiple suppliers
  notes       String?         // Supplier's private notes about this client
  
  createdAt   DateTime        @default(now())
  
  @@unique([supplierId, clientId])
  @@index([supplierId])
  @@index([clientId])
}

// ─── INVITATIONS ──────────────────────────────────────────────────────────────

model Invitation {
  id          String           @id @default(cuid())
  email       String
  token       String           @unique
  type        InvitationType
  
  // Who sent the invitation
  invitedBy   String           // User ID
  
  // For CLIENT invitations - which supplier is inviting
  supplierId  String?          // SupplierProfile ID
  
  // Status tracking
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  acceptedByUserId String?     // Set when invitation is accepted
  
  // Metadata
  companyName String?          // For SUPPLIER invites
  notes       String?          // Optional message
  
  createdAt   DateTime         @default(now())
  
  @@index([token])
  @@index([email])
  @@index([status])
  @@index([supplierId])
}

// ─── ACTIVITY LOG ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String          @id @default(cuid())
  supplierId  String?
  supplier    SupplierProfile? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  clientId    String?         // User ID of the client who performed the action
  
  type        ActivityType
  metadata    Json?           // Flexible metadata based on activity type
  
  // For quotes
  quoteId     String?
  
  createdAt   DateTime        @default(now())
  
  @@index([supplierId])
  @@index([clientId])
  @@index([type])
  @@index([createdAt])
}

// ─── QUOTES ───────────────────────────────────────────────────────────────────

model Quote {
  id                String      @id @default(cuid())
  quoteNumber       String      @unique
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            QuoteStatus @default(DRAFT)

  productType       ProductType
  quantity          Int

  formatName        String
  formatWidth       Decimal
  formatHeight      Decimal
  openFormatWidth   Decimal?
  openFormatHeight  Decimal?

  pagesInterior     Int?
  pagesCover        Int?
  flapSize          Decimal?

  paperInteriorType String?
  paperInteriorGram Int?
  paperCoverType    String?
  paperCoverGram    Int?

  colorModeInterior String?
  colorModeCover    String?
  rectoVerso        Boolean     @default(false)

  bindingType       String?
  foldType          String?
  foldCount         Int?
  secondaryFoldType String?
  secondaryFoldCount Int?

  laminationMode    String?
  laminationFinish  String?

  packaging         Json?
  deliveryPoints    Json?

  // Legacy single-supplier fields (kept for backward compatibility)
  digitalPrice      Decimal?
  offsetPrice       Decimal?
  digitalBreakdown  Json?
  offsetBreakdown   Json?
  deliveryCost      Decimal?
  selectedMethod    String?

  weightPerCopy     Decimal?
  totalWeight       Decimal?

  // NEW: Multi-supplier quote support
  // Stores results for all suppliers that were compared
  multiSupplierResults Json?    // { [supplierId: string]: { price, breakdown, method, ... } }
  
  // Which supplier the client selected (if any)
  selectedSupplierId String?
  
  // PDF tracking
  pdfDownloaded     Boolean     @default(false)
  pdfDownloadedAt   DateTime?
  pdfDownloadCount  Int         @default(0)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([selectedSupplierId])
}

// ─── PAPER CONFIG ─────────────────────────────────────────────────────────────
// NOTE: When fournisseurId is NULL, these are DEFAULT configs managed by Super Admin

model PaperType {
  id             String          @id @default(cuid())
  supplierId     String?         // NULL = default config (Super Admin managed)
  name           String
  category       PaperCategory   @default(BOTH)
  active         Boolean         @default(true)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  grammages      PaperGrammage[]

  @@unique([supplierId, name])
  @@index([supplierId])
}

model PaperGrammage {
  id                    String    @id @default(cuid())
  paperTypeId           String
  paperType             PaperType @relation(fields: [paperTypeId], references: [id], onDelete: Cascade)
  grammage              Int
  pricePerKg            Decimal
  weightPer1000Sheets   Decimal?
  thicknessPer100       Decimal?  // Spine thickness per 100 sheets (in mm)
  availableForDosCarre  Boolean   @default(true)
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([paperTypeId, grammage])
  @@index([paperTypeId])
}

// ─── FORMAT CONFIG ────────────────────────────────────────────────────────────

model FormatPreset {
  id             String        @id @default(cuid())
  supplierId     String?       // NULL = default config
  name           String
  widthCm        Decimal
  heightCm       Decimal
  orientation    Orientation   @default(PORTRAIT)
  productTypes   Json          @default("[]")
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
}

// ─── COLOR CONFIG ─────────────────────────────────────────────────────────────

model ColorMode {
  id              String    @id @default(cuid())
  supplierId      String?   // NULL = default config
  name            String
  platesPerSide   Int
  hasVarnish      Boolean   @default(false)
  clickMultiplier Decimal   @default(1.0)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
}

// ─── BINDING / FINISHING CONFIG ───────────────────────────────────────────────

model BindingType {
  id                String                    @id @default(cuid())
  supplierId        String?                   // NULL = default config
  name              String
  minPages          Int
  maxPages          Int?
  active            Boolean                   @default(true)
  
  // JSON rules for specific binding penalties (e.g. heavy paper, extreme spines)
  rules             Json?

  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  digitalPriceTiers BindingPriceTierDigital[]
  offsetPriceTiers  BindingPriceTierOffset[]

  @@unique([supplierId, name])
  @@index([supplierId])
}

model BindingPriceTierDigital {
  id            String      @id @default(cuid())
  bindingTypeId String
  bindingType   BindingType @relation(fields: [bindingTypeId], references: [id], onDelete: Cascade)
  pageRangeMin  Int
  pageRangeMax  Int
  qtyMin        Int
  qtyMax        Int
  perUnitCost   Decimal
  setupCost     Decimal     @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([bindingTypeId])
}

model BindingPriceTierOffset {
  id              String      @id @default(cuid())
  bindingTypeId   String
  bindingType     BindingType @relation(fields: [bindingTypeId], references: [id], onDelete: Cascade)
  cahiersCount    Int
  calageCost      Decimal
  roulagePer1000  Decimal
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([bindingTypeId])
}

// ─── FOLD CONFIG ──────────────────────────────────────────────────────────────

model FoldType {
  id              String      @id @default(cuid())
  supplierId      String?     // NULL = default config
  name            String
  maxFolds        Int         @default(6)
  canBeSecondary  Boolean     @default(false)
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  costs           FoldCost[]

  @@unique([supplierId, name])
  @@index([supplierId])
}

model FoldCost {
  id          String    @id @default(cuid())
  foldTypeId  String
  foldType    FoldType  @relation(fields: [foldTypeId], references: [id], onDelete: Cascade)
  numFolds    Int
  cost        Decimal
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([foldTypeId, numFolds])
  @@index([foldTypeId])
}

// ─── LAMINATION CONFIG ────────────────────────────────────────────────────────

model LaminationMode {
  id             String    @id @default(cuid())
  supplierId     String?   // NULL = default config
  name           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
}

model LaminationFinish {
  id                    String                  @id @default(cuid())
  supplierId            String?                 // NULL = default config
  name                  String
  offsetPricePerM2      Decimal?
  offsetCalageForfait   Decimal?
  offsetMinimumBilling  Decimal?
  active                Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  digitalPriceTiers     LaminationPriceTier[]

  @@unique([supplierId, name])
  @@index([supplierId])
}

model LaminationPriceTier {
  id            String            @id @default(cuid())
  finishId      String
  finish        LaminationFinish  @relation(fields: [finishId], references: [id], onDelete: Cascade)
  qtyMin        Int
  qtyMax        Int
  pricePerSheet Decimal
  setupCost     Decimal           @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([finishId])
}

// ─── PACKAGING CONFIG ─────────────────────────────────────────────────────────

model PackagingOption {
  id             String    @id @default(cuid())
  supplierId     String?   // NULL = default config
  name           String
  type           String
  costPerUnit    Decimal   @default(0)
  costPerOrder   Decimal   @default(0)
  appliesTo      Json      @default("[]")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
}

// ─── DELIVERY CONFIG ──────────────────────────────────────────────────────────

model Department {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  zone          Int
  isSpecialZone Boolean   @default(false)
  displayName   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([zone])
}

model Carrier {
  id                    String                 @id @default(cuid())
  supplierId            String?                // NULL = default config
  name                  String
  active                Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deliveryRates         DeliveryRate[]
  transportRatesByDept  TransportRateByDept[]

  @@unique([supplierId, name])
  @@index([supplierId])
}

model DeliveryRate {
  id          String    @id @default(cuid())
  carrierId   String
  carrier     Carrier   @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  zone        Int
  maxWeightKg Decimal
  price       Decimal
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([carrierId, zone, maxWeightKg])
  @@index([carrierId])
  @@index([zone])
}

// Per-department per-weight matrix (XLSM Transports.csv). When present, overrides zone-based rate.
model TransportRateByDept {
  id             String   @id @default(cuid())
  carrierId      String
  carrier        Carrier  @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  departmentCode String   // e.g. "14 - Calvados"
  maxWeightKg    Decimal  // upper bound of bracket (1, 2, 3, ... 10000)
  price          Decimal
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([carrierId])
  @@index([departmentCode])
  @@index([carrierId, departmentCode])
}

// ─── OFFSET / DIGITAL / MARGIN CONFIG (Key-Value) ─────────────────────────────
// NOTE: When supplierId is NULL, these are DEFAULT configs managed by Super Admin

model OffsetConfig {
  id             String    @id @default(cuid())
  supplierId     String?   // NULL = default config (Super Admin managed)
  key            String
  value          Decimal
  unit           String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([supplierId, key])
  @@index([supplierId])
}

model DigitalConfig {
  id             String    @id @default(cuid())
  supplierId     String?   // NULL = default config (Super Admin managed)
  key            String
  value          Decimal
  unit           String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([supplierId, key])
  @@index([supplierId])
}

// ─── MARGIN CONFIG ─────────────────────────────────────────────────────────────

model MarginConfig {
  id             String    @id @default(cuid())
  supplierId     String?   // NULL = default config (Super Admin managed)
  key            String    // Expected keys: "digital_markup", "offset_markup", "paper_margin"
  value          Decimal
  unit           String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([supplierId, key])
  @@index([supplierId])
}

// ─── MACHINE / IMPOSITION CONFIG ──────────────────────────────────────────────

model MachineFormat {
  id             String    @id @default(cuid())
  supplierId     String?   // NULL = default config (Super Admin managed)
  name           String
  widthCm        Decimal
  heightCm       Decimal
  isDefault      Boolean   @default(false)
  active         Boolean   @default(true)
  
  // JSON configurations for machine-specific pricing/waste
  defaultWasteRatio Decimal?  // e.g., 0.02
  wasteTiers        Json?     // [{ "max": 3000, "ratio": 0.05 }, ...]
  runningCostTiers  Json?     // [{ "max": 1000, "cost": 25 }, { "max": 3000, "cost": 15 }]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
}

model FormatClickDivisor {
  id                String    @id @default(cuid())
  supplierId        String?   // NULL = default config (Super Admin managed)
  formatName        String
  divisorRecto      Decimal
  divisorRectoVerso Decimal
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([supplierId, formatName])
  @@index([supplierId])
}

// ─── DIGITAL CUTTING CONFIG ───────────────────────────────────────────────────

model DigitalCutTier {
  id             String      @id @default(cuid())
  supplierId     String?     // NULL = default config (Super Admin managed)
  productType    ProductType // BROCHURE vs FLYER
  qtyMax         Int
  perUnitCost    Decimal
  setupCost      Decimal     @default(10.0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([supplierId])
  @@index([supplierId, productType])
}

// ─── DEFAULT CONFIG MANAGEMENT ────────────────────────────────────────────────
// Tracks which config items have been copied from defaults to supplier

model SupplierConfigStatus {
  id             String    @id @default(cuid())
  supplierId     String    @unique
  
  // Flags for each config category
  hasPaperTypes         Boolean @default(false)
  hasFormatPresets      Boolean @default(false)
  hasColorModes         Boolean @default(false)
  hasBindingTypes       Boolean @default(false)
  hasFoldTypes          Boolean @default(false)
  hasLamination         Boolean @default(false)
  hasPackaging          Boolean @default(false)
  hasCarriers           Boolean @default(false)
  hasOffsetConfig       Boolean @default(false)
  hasDigitalConfig      Boolean @default(false)
  hasMarginConfig       Boolean @default(false)
  hasMachineFormats     Boolean @default(false)
  hasDigitalCutTiers    Boolean @default(false)
  
  // When defaults were last copied
  lastCopiedAt   DateTime?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@index([supplierId])
}
